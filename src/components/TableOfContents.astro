---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
}

const { headings } = Astro.props;

// 只显示 h2 和 h3
const tocHeadings = headings.filter(h => h.depth >= 2 && h.depth <= 3);
---

{tocHeadings.length > 0 && (
  <div class="toc-container hidden lg:block">
    <div class="sticky top-24">
      <div class="bg-[var(--card-bg)] rounded-xl border border-[var(--card-border)] p-4">
        <h3 class="font-semibold text-[var(--text-main)] mb-3 flex items-center gap-2">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7"></path>
          </svg>
          目录
        </h3>
        <nav class="toc-nav max-h-[calc(100vh-200px)] overflow-y-auto">
          <ul class="space-y-1">
            {tocHeadings.map((heading, index) => (
              <li class={`${heading.depth === 3 ? 'ml-3' : ''}`}>
                <a
                  href={`#${heading.slug}`}
                  class={`toc-link block py-1.5 px-2 rounded-lg text-sm transition-all duration-200
                    ${heading.depth === 2 ? 'font-medium text-[var(--text-main)]' : 'text-[var(--text-muted)] text-xs'}
                    hover:bg-[var(--primary)]/10 hover:text-[var(--primary)]`}
                  data-heading-id={heading.slug}
                >
                  {heading.text}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </div>
      
      <!-- Back to top button -->
      <button
        id="back-to-top"
        class="mt-4 w-full py-2 px-4 rounded-xl bg-[var(--card-bg)] border border-[var(--card-border)]
               text-[var(--text-muted)] text-sm hover:border-[var(--primary)] hover:text-[var(--primary)]
               transition-all duration-300 flex items-center justify-center gap-2 opacity-0 pointer-events-none"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"></path>
        </svg>
        回到顶部
      </button>
    </div>
  </div>
)}

<script>
  // 高亮当前阅读的章节
  const tocLinks = document.querySelectorAll('.toc-link');
  const headings = document.querySelectorAll('h2[id], h3[id]');
  const backToTop = document.getElementById('back-to-top');
  
  let activeHeading: Element | null = null;
  
  function updateActiveHeading() {
    const scrollPos = window.scrollY + 100;
    
    // 找到当前可见的标题
    let currentHeading: Element | null = null;
    for (const heading of headings) {
      const headingTop = (heading as HTMLElement).offsetTop;
      if (headingTop <= scrollPos) {
        currentHeading = heading;
      } else {
        break;
      }
    }
    
    if (currentHeading !== activeHeading) {
      activeHeading = currentHeading;
      
      // 更新 TOC 高亮
      tocLinks.forEach(link => {
        link.classList.remove('bg-[var(--primary)]/10', 'text-[var(--primary)]');
        if (currentHeading && link.getAttribute('data-heading-id') === currentHeading.id) {
          link.classList.add('bg-[var(--primary)]/10', 'text-[var(--primary)]');
        }
      });
    }
    
    // 显示/隐藏回到顶部按钮
    if (backToTop) {
      if (window.scrollY > 500) {
        backToTop.classList.remove('opacity-0', 'pointer-events-none');
      } else {
        backToTop.classList.add('opacity-0', 'pointer-events-none');
      }
    }
  }
  
  // 平滑滚动到锚点
  tocLinks.forEach(link => {
    link.addEventListener('click', (e) => {
      e.preventDefault();
      const targetId = link.getAttribute('href')?.slice(1);
      const target = document.getElementById(targetId || '');
      if (target) {
        const offset = 80;
        const targetPosition = target.getBoundingClientRect().top + window.scrollY - offset;
        window.scrollTo({
          top: targetPosition,
          behavior: 'smooth'
        });
      }
    });
  });
  
  // 回到顶部
  backToTop?.addEventListener('click', () => {
    window.scrollTo({
      top: 0,
      behavior: 'smooth'
    });
  });
  
  // 监听滚动
  let ticking = false;
  window.addEventListener('scroll', () => {
    if (!ticking) {
      requestAnimationFrame(updateActiveHeading);
      ticking = true;
    }
  }, { passive: true });
  
  // 初始化
  updateActiveHeading();
</script>

<style>
  .toc-nav::-webkit-scrollbar {
    width: 4px;
  }
  .toc-nav::-webkit-scrollbar-track {
    background: transparent;
  }
  .toc-nav::-webkit-scrollbar-thumb {
    background: var(--card-border);
    border-radius: 2px;
  }
</style>
