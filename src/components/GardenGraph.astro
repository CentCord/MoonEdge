---
interface Node {
  id: string;
  title: string;
  tags: string[];
  date: Date;
}

interface Link {
  source: string;
  target: string;
  strength: number;
}

interface Props {
  nodes: Node[];
  links: Link[];
}

const { nodes, links } = Astro.props;
---

<div class="garden-graph bg-[var(--card-bg)] rounded-xl border border-[var(--card-border)] p-6 overflow-hidden">
  <div id="graph-container" class="relative w-full h-[400px]">
    <canvas id="graph-canvas" class="w-full h-full"></canvas>
    
    <!-- Tooltip -->
    <div 
      id="graph-tooltip" 
      class="absolute hidden bg-[var(--card-bg)] border border-[var(--card-border)] 
             rounded-lg p-3 shadow-lg pointer-events-none z-10 max-w-xs"
    >
      <div class="font-semibold text-[var(--text-main)]" id="tooltip-title"></div>
      <div class="text-sm text-[var(--text-muted)] mt-1" id="tooltip-tags"></div>
    </div>
  </div>
  
  <div class="flex justify-center gap-4 mt-4 text-sm text-[var(--text-muted)]">
    <div class="flex items-center gap-2">
      <span class="w-3 h-3 rounded-full bg-[var(--primary)]"></span>
      <span>文章节点</span>
    </div>
    <div class="flex items-center gap-2">
      <span class="w-8 h-0.5 bg-[var(--primary)]/30"></span>
      <span>相关连接</span>
    </div>
  </div>
</div>

<script define:vars={{ nodes, links }}>
  const canvas = document.getElementById('graph-canvas');
  const ctx = canvas.getContext('2d');
  const tooltip = document.getElementById('graph-tooltip');
  const tooltipTitle = document.getElementById('tooltip-title');
  const tooltipTags = document.getElementById('tooltip-tags');
  const container = document.getElementById('graph-container');
  
  let width, height;
  let animationId;
  let hoveredNode = null;
  let draggedNode = null;
  let mouseX = 0;
  let mouseY = 0;
  
  // 初始化节点位置
  const nodePositions = nodes.map((node, i) => ({
    ...node,
    x: Math.random() * 400 + 50,
    y: Math.random() * 300 + 50,
    vx: 0,
    vy: 0,
    radius: 6 + Math.sqrt(node.tags.length) * 2,
  }));
  
  function resize() {
    const rect = container.getBoundingClientRect();
    width = rect.width;
    height = rect.height;
    canvas.width = width * window.devicePixelRatio;
    canvas.height = height * window.devicePixelRatio;
    canvas.style.width = width + 'px';
    canvas.style.height = height + 'px';
    ctx.scale(window.devicePixelRatio, window.devicePixelRatio);
  }
  
  function updatePhysics() {
    const centerX = width / 2;
    const centerY = height / 2;
    
    // 向中心的引力
    nodePositions.forEach(node => {
      const dx = centerX - node.x;
      const dy = centerY - node.y;
      node.vx += dx * 0.0001;
      node.vy += dy * 0.0001;
    });
    
    // 节点间的斥力
    for (let i = 0; i < nodePositions.length; i++) {
      for (let j = i + 1; j < nodePositions.length; j++) {
        const a = nodePositions[i];
        const b = nodePositions[j];
        const dx = b.x - a.x;
        const dy = b.y - a.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < 100 && dist > 0) {
          const force = (100 - dist) * 0.001;
          const fx = (dx / dist) * force;
          const fy = (dy / dist) * force;
          a.vx -= fx;
          a.vy -= fy;
          b.vx += fx;
          b.vy += fy;
        }
      }
    }
    
    // 连接的引力
    links.forEach(link => {
      const source = nodePositions.find(n => n.id === link.source);
      const target = nodePositions.find(n => n.id === link.target);
      if (source && target) {
        const dx = target.x - source.x;
        const dy = target.y - source.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist > 0) {
          const force = (dist - 80) * 0.001 * link.strength;
          const fx = (dx / dist) * force;
          const fy = (dy / dist) * force;
          source.vx += fx;
          source.vy += fy;
          target.vx -= fx;
          target.vy -= fy;
        }
      }
    });
    
    // 更新位置
    nodePositions.forEach(node => {
      if (node !== draggedNode) {
        node.vx *= 0.9; // 阻尼
        node.vy *= 0.9;
        node.x += node.vx;
        node.y += node.vy;
        
        // 边界限制
        node.x = Math.max(node.radius, Math.min(width - node.radius, node.x));
        node.y = Math.max(node.radius, Math.min(height - node.radius, node.y));
      }
    });
  }
  
  function draw() {
    ctx.clearRect(0, 0, width, height);
    
    // 绘制连接线
    links.forEach(link => {
      const source = nodePositions.find(n => n.id === link.source);
      const target = nodePositions.find(n => n.id === link.target);
      if (source && target) {
        ctx.beginPath();
        ctx.moveTo(source.x, source.y);
        ctx.lineTo(target.x, target.y);
        ctx.strokeStyle = `rgba(var(--primary-rgb, 100, 100, 255), ${0.1 + link.strength * 0.1})`;
        ctx.lineWidth = link.strength;
        ctx.stroke();
      }
    });
    
    // 绘制节点
    nodePositions.forEach(node => {
      // 节点发光效果
      if (node === hoveredNode) {
        const gradient = ctx.createRadialGradient(
          node.x, node.y, 0,
          node.x, node.y, node.radius * 3
        );
        gradient.addColorStop(0, 'rgba(var(--primary-rgb, 100, 100, 255), 0.3)');
        gradient.addColorStop(1, 'rgba(var(--primary-rgb, 100, 100, 255), 0)');
        ctx.fillStyle = gradient;
        ctx.beginPath();
        ctx.arc(node.x, node.y, node.radius * 3, 0, Math.PI * 2);
        ctx.fill();
      }
      
      // 节点本体
      ctx.beginPath();
      ctx.arc(node.x, node.y, node.radius, 0, Math.PI * 2);
      ctx.fillStyle = node === hoveredNode ? 'var(--primary)' : 'var(--primary)';
      ctx.globalAlpha = node === hoveredNode ? 1 : 0.7;
      ctx.fill();
      ctx.globalAlpha = 1;
      
      // 节点边框
      ctx.strokeStyle = 'var(--card-bg)';
      ctx.lineWidth = 2;
      ctx.stroke();
    });
  }
  
  function animate() {
    updatePhysics();
    draw();
    animationId = requestAnimationFrame(animate);
  }
  
  // 鼠标交互
  canvas.addEventListener('mousemove', (e) => {
    const rect = canvas.getBoundingClientRect();
    mouseX = (e.clientX - rect.left) * (width / rect.width);
    mouseY = (e.clientY - rect.top) * (height / rect.height);
    
    if (draggedNode) {
      draggedNode.x = mouseX;
      draggedNode.y = mouseY;
      draggedNode.vx = 0;
      draggedNode.vy = 0;
      return;
    }
    
    // 查找悬停的节点
    let found = null;
    for (const node of nodePositions) {
      const dx = mouseX - node.x;
      const dy = mouseY - node.y;
      if (Math.sqrt(dx * dx + dy * dy) < node.radius + 5) {
        found = node;
        break;
      }
    }
    
    hoveredNode = found;
    
    if (hoveredNode) {
      tooltipTitle.textContent = hoveredNode.title;
      tooltipTags.textContent = hoveredNode.tags.slice(0, 3).join(', ');
      tooltip.classList.remove('hidden');
      tooltip.style.left = (e.clientX - rect.left + 10) + 'px';
      tooltip.style.top = (e.clientY - rect.top - 50) + 'px';
      canvas.style.cursor = 'pointer';
    } else {
      tooltip.classList.add('hidden');
      canvas.style.cursor = 'default';
    }
  });
  
  canvas.addEventListener('mousedown', (e) => {
    if (hoveredNode) {
      draggedNode = hoveredNode;
    }
  });
  
  canvas.addEventListener('mouseup', () => {
    draggedNode = null;
  });
  
  canvas.addEventListener('mouseleave', () => {
    draggedNode = null;
    hoveredNode = null;
    tooltip.classList.add('hidden');
  });
  
  canvas.addEventListener('click', (e) => {
    if (hoveredNode) {
      window.location.href = `/posts/${hoveredNode.id}/`;
    }
  });
  
  // 初始化
  resize();
  animate();
  
  window.addEventListener('resize', resize);
</script>

<style>
  .garden-graph canvas {
    touch-action: none;
  }
</style>
